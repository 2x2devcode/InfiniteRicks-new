<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rick_background"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp"
    android:paddingTop="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/qrImage"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:contentDescription="QR Code do endereço"
            android:padding="8dp" />

        <TextView
            android:id="@+id/addressValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/rick_text"
            android:textIsSelectable="true" />

        <Button
            android:id="@+id/copyAddressButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/rick_green"
            android:text="Copiar endereço" />

        <EditText
            android:id="@+id/restoreWifInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="WIF de backup"
            android:inputType="textPassword"
            android:textColor="@color/rick_text"
            android:textColorHint="@color/rick_muted" />

        <Button
            android:id="@+id/restoreWifButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/rick_green"
            android:text="Restaurar WIF" />
    </LinearLayout>
</ScrollView>
