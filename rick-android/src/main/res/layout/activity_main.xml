<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rick_background">

    <ScrollView
        android:id="@+id/authContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/authTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rick_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/wifRestoreInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="WIF da carteira"
                android:inputType="textVisiblePassword|textNoSuggestions"
                android:textColor="@color/rick_text"
                android:textColorHint="@color/rick_muted"
                android:visibility="gone" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:digits="0123456789"
                android:hint="Senha numérica (6-10 dígitos)"
                android:imeOptions="actionDone"
                android:inputType="numberPassword"
                android:maxLength="10"
                android:textColor="@color/rick_text"
                android:textColorHint="@color/rick_muted" />

            <Button
                android:id="@+id/authActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/rick_green"
                android:text="Entrar" />

            <Button
                android:id="@+id/authSecondaryButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Criar nova carteira"
                android:textColor="@color/rick_muted" />

            <Button
                android:id="@+id/authRestoreButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurar carteira"
                android:textColor="@color/rick_muted" />

            <Button
                android:id="@+id/authBiometricButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Entrar com biometria"
                android:textColor="@color/rick_green"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/walletContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/rick_surface"
            app:itemIconTint="@color/rick_green"
            app:itemTextColor="@color/rick_text"
            app:menu="@menu/bottom_nav" />
    </LinearLayout>
</FrameLayout>
